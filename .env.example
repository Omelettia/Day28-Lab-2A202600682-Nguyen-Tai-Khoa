# ── LLM backend ───────────────────────────────────────────────────────────
# Leave VLLM_NGROK_URL BLANK to use the local Ollama service that ships in the
# stack (docker-compose defaults VLLM_URL to http://ollama:11434/v1).
#
# To use a hosted OpenAI-compatible API instead (e.g. Groq), set both:
#   VLLM_NGROK_URL=https://api.groq.com/openai/v1
#   MODEL_NAME=llama-3.1-8b-instant
#   LLM_API_KEY=gsk_your_key
# The URL must include the OpenAI base path (…/v1).
VLLM_NGROK_URL=
MODEL_NAME=qwen2.5:3b
LLM_API_KEY=

# ── LangSmith tracing (Integration 10 / Observability) ──
LANGCHAIN_API_KEY=ls__your_langsmith_key
LANGCHAIN_PROJECT=lab28-platform
LANGCHAIN_TRACING_V2=true

# ── Local overrides (usually leave as-is) ──
# Host scripts reach Kafka on localhost; the Prefect worker container reaches it
# as kafka:29092 (set automatically in docker-compose).
KAFKA_BOOTSTRAP=localhost:9092
